{
  "name": "fibbage-server",
  "version": "1.0.0",
  "description": "Fibbage game server with socket.io",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "docker:build": "docker build -t fibbage-server .",
    "docker:run": "docker run -p 3001:3001 --name fibbage-server fibbage-server",
    "docker:stop": "docker stop fibbage-server && docker rm fibbage-server"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/cors": "^2.8.13",
    "@types/uuid": "^9.0.0",
    "tsx": "^4.6.0",
    "typescript": "^5.0.0"
  }
}

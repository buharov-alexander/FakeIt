# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/client/node_modules
/server/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/client/coverage
/server/coverage

# Playwright test results
/test-results/
/playwright-report/
/playwright/.cache/

# next.js
/.next/
/client/.next/
/out/
/client/out/

# production
/build
/client/build
/server/build
/server/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
/client/.env*
/server/.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/client/*.tsbuildinfo
/client/next-env.d.ts
/server/*.tsbuildinfo

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
